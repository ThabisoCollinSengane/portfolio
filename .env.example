# Supabase — your project URL and service role key
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Resend — for email notifications when new leads are found
# Get from: resend.com (free tier = 3000 emails/month)
RESEND_API_KEY=re_your_resend_key_here

# A SEPARATE email just for lead notifications
# ⚠️  Do NOT use thacollin2@gmail.com — keep this completely separate
# Example: create a new Gmail like tcdev.leads@gmail.com
LEADS_EMAIL=your-leads-only-email@gmail.com

# Any random secret string — used to protect the /api/scrape-leads endpoint
# Generate one at: https://1password.com/password-generator/ or just type random chars
SCRAPER_TOKEN=change-me-to-a-random-secret-string
